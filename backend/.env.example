# Azure Entra (Azure AD) App Registration
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret

# Microsoft Entra Verified ID
VC_AUTHORITY_DID=did:web:yourdomain.com

# Your app public HTTPS base URL (used for callbacks)
APP_BASE_URL=https://yourdomain.com

# Optional: protect callbacks with an API key
VC_API_KEY=change-me

# CORS origins (comma-separated in production)
CORS_ORIGINS=["http://localhost:4200","https://yourdomain.com"]

# Verification ID Issuer Request
ISSUER_REQUEST=True

# API protection
# Leave disabled until the Angular frontend is configured with Entra ID login.
AUTH_ENABLED=False

# Backend API token validation
# Usually the Application ID URI or the API app client ID expected in the access token audience.
# You can provide multiple comma-separated values if needed.
AUTH_AUDIENCE=api://xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx,xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Optional override for accepted token issuers. Defaults cover Entra v2 and sts.windows.net.
AUTH_ISSUERS=
# Optional override for the OpenID configuration endpoint.
AUTH_OPENID_CONFIG_URL=
AUTH_JWKS_CACHE_TTL_SECONDS=3600

# Role or scope names expected by the backend
AUTH_ROLE_HELPDESK=helpdesk
AUTH_ROLE_HR=hr
# Optional delegated scope accepted for helpdesk endpoints such as /assist
AUTH_SCOPE_HELPDESK=access_as_user

# Frontend Entra ID configuration returned by /api/v1/status
# This must be the SPA app registration client ID.
FRONTEND_AUTH_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Optional override. Defaults to https://login.microsoftonline.com/<tenant-id>
FRONTEND_AUTH_AUTHORITY=
# Comma-separated scopes requested by the Angular app for this API.
FRONTEND_AUTH_SCOPES=api://xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx/access_as_user

# Logo url
LOGO_URL="https://placehold.co/140x36/FFFFFF/122147?text=Logo"
